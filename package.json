{
  "name": "raytonx-nest-modules",
  "version": "0.0.0",
  "private": true,
  "description": "A monorepo for independently installable NestJS modules.",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "clean": "pnpm -r --filter './packages/*' clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.5.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20.12.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.5.0"
  }
}
