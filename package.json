{
  "name": "raytonx-nest-modules",
  "version": "0.0.0",
  "private": true,
  "description": "A monorepo for independently installable NestJS modules.",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/raytonx-labs/raytonx-nest-modules.git"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "changeset": "changeset",
    "clean": "pnpm -r --filter './packages/*' clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.5.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20.12.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.5.0"
  }
}
